# ── LLM Backend ─────────────────────────────────────────────────────────────────
# Choose "anthropic" or "openai"
LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Model to use (defaults to claude-haiku-4-5-20251001 for Anthropic, gpt-4o-mini for OpenAI)
LLM_MODEL=claude-haiku-4-5-20251001

# ── Admin ────────────────────────────────────────────────────────────────────────
# Keep this secret — used to create tenant API keys via POST /v1/admin/keys
ADMIN_API_KEY=change_this_to_a_long_random_secret

# ── Database ─────────────────────────────────────────────────────────────────────
# SQLite for local dev. Switch to PostgreSQL for production:
# DATABASE_URL=postgresql://user:pass@host:5432/rag_service
DATABASE_URL=sqlite:///./rag_service.db

# ── Caching ──────────────────────────────────────────────────────────────────────
# Leave empty to use in-memory fallback (single-instance only)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600

# ── Storage ───────────────────────────────────────────────────────────────────────
INDICES_DIR=./indices
UPLOADS_DIR=./uploads

# ── Rate Limiting ─────────────────────────────────────────────────────────────────
# Max requests per minute per API key
RATE_LIMIT_RPM=60

# ── Retrieval ─────────────────────────────────────────────────────────────────────
DEFAULT_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Embeddings ────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Observability ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/rag_service.jsonl
